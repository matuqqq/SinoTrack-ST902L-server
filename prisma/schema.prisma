datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

model User {
  id            Int            @id @default(autoincrement())
  username      String         @unique
  email         String         @unique
  passwordHash  String
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model ApiKey {
  id        Int       @id @default(autoincrement())
  name      String
  keyHash   String    @unique
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  active    Boolean   @default(true)
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Vehicle {
  id             String           @id
  name           String?
  plate          String?
  color          String?          @default("#3B82F6")
  speedLimit     Float?
  createdAt      DateTime         @default(now())
  reports        LocationReport[]
  trips          Trip[]
  geofenceEvents GeofenceEvent[]
}

model LocationReport {
  id        Int      @id @default(autoincrement())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  timestamp DateTime
  validGps  Boolean
  latitude  Float
  longitude Float
  speed     Float
  course    Float
  statusHex String
  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([timestamp])
  @@index([vehicleId, timestamp])
}

model Geofence {
  id        Int             @id @default(autoincrement())
  name      String
  type      String          @default("circle")
  latitude  Float?
  longitude Float?
  radius    Float?
  polygon   Json?
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  events    GeofenceEvent[]
}

model GeofenceEvent {
  id         Int      @id @default(autoincrement())
  geofenceId Int
  geofence   Geofence @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type       String
  latitude   Float
  longitude  Float
  timestamp  DateTime @default(now())

  @@index([vehicleId])
  @@index([geofenceId])
}

model Trip {
  id        Int       @id @default(autoincrement())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime?
  distance  Float     @default(0)
  maxSpeed  Float     @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([vehicleId])
}

model Webhook {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  events    Json
  secret    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Alert {
  id        Int      @id @default(autoincrement())
  type      String
  vehicleId String?
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt])
  @@index([type])
}
