# ══════════════════════════════════════════
# SinoTrack ST902L Server — Template
# Copiar a .env y completar valores
# ══════════════════════════════════════════

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sinotrack?schema=public"

TCP_PORT=5013
HTTP_PORT=3000

# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

CORS_ORIGIN="https://tu-dominio.com"

RETENTION_DAYS=90
DEVICE_TIMEOUT_MINUTES=10
TRIP_IDLE_MINUTES=5
IDLE_ALERT_MINUTES=10

# Email SMTP (opcional — dejar vacío para deshabilitar)
# Gmail: usar App Password en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL=
